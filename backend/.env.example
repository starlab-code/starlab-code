# ---- Authentication ----
# Generate a long random secret:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
STARLAB_SECRET_KEY=change-me-to-a-long-random-string
STARLAB_TOKEN_MINUTES=1440
STARLAB_PRIMARY_TEACHER_USERNAME=main_teacher
STARLAB_PRIMARY_TEACHER_DISPLAY_NAME=메인 선생님
STARLAB_PRIMARY_TEACHER_PASSWORD=ChangeMe1234!

# ---- Database ----
# Local development fallback:
# STARLAB_DATABASE_URL=sqlite:///./starlab_code_mvp.db
#
# Production example for Supabase Session pooler:
# STARLAB_DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
# Set to false to skip auto-seeding the default problem catalog.
STARLAB_SEED_DEMO_DATA=true
STARLAB_DB_POOL_SIZE=5
STARLAB_DB_MAX_OVERFLOW=5
STARLAB_DB_POOL_RECYCLE_SECONDS=300

# ---- CORS ----
# Comma-separated list. Do not use "*" in production.
STARLAB_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Concurrency / Judge ----
STARLAB_THREADPOOL_SIZE=64
STARLAB_JUDGE_CONCURRENCY=2
STARLAB_MAX_CODE_BYTES=65536
STARLAB_MAX_INPUT_BYTES=262144
STARLAB_MAX_OUTPUT_BYTES=262144
STARLAB_JUDGE_CPU_SECONDS=4
STARLAB_JUDGE_MEMORY_BYTES=268435456
