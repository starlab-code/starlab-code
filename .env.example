# Backend API URL used by the Windows desktop installer build.
# Example: https://starlab-code-api.onrender.com
STARLAB_API_BASE_URL=https://your-backend.example.com

# Optional: only use this if you want the desktop app to open a deployed web URL
# instead of packaging the frontend into the installer.
# STARLAB_DESKTOP_URL=https://your-frontend.example.com

# Optional: desktop app update metadata served by the backend /desktop/update endpoint.
# Set these on the deployed backend after uploading a new installer.
# STARLAB_DESKTOP_LATEST_VERSION=0.1.1
# STARLAB_DESKTOP_DOWNLOAD_URL=https://your-download-host.example.com/Starlab-Code-Setup-0.1.1.exe
# STARLAB_DESKTOP_RELEASE_NOTES=Bug fixes and UI improvements.
# STARLAB_DESKTOP_FORCE_UPDATE=false
